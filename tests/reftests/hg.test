### <pkg:hugdore.3>
opam-version: "2.0"
### <mkurl.sh>
p=hugdore.3
arch=origin
file="REPO/packages/${p%.*}/$p/opam"
MD5=$(openssl md5 $arch.tgz | cut -d' ' -f2)
basedir=$(printf '%s' "$BASEDIR" | sed 's/\\/\\\\/g')
cat >> "$file" << EOF
url {
  hg: "$basedir/hugdev"
}
dev-repo: "hg+file://${basedir}/hugdev"
EOF
### sh mkurl.sh
### opam update

