### <pkg:darkdore.3>
opam-version: "2.0"
### <mkurl.sh>
p=darkdore.3
arch=origin
file="REPO/packages/${p%.*}/$p/opam"
MD5=$(openssl md5 $arch.tgz | cut -d' ' -f2)
basedir=$(printf '%s' "$BASEDIR" | sed 's/\\/\\\\/g')
cat >> "$file" << EOF
url {
  darcs: "$basedir/darkdev"
}
dev-repo: "darcs+file://${basedir}/darkdev"
EOF
### sh mkurl.sh
### opam update

