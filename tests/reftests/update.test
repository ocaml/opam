### <add-xf.sh>
set -eu
nv=$1
file=$2
n=${nv%.*}
path="DREPO/packages/$n/$nv"
md5=$(openssl md5 "$path/files/$file" | cut -d' ' -f2)
cat >> "$path/opam" << EOF
build: [ "test" "-f" "$file" ]
extra-files: [
  [ "$file" "md5=$md5" ]
]
EOF
