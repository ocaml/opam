N0REP0
### <pkg:pkg++.1>
opam-version: "2.0"
### <pkg:pkg+.1>
opam-version: "2.0"
### <pkg:pkg+a.1>
opam-version: "2.0"
### <pkg:pkg++a.1>
opam-version: "2.0"
### <pkg:pkg1.1>
opam-version: "2.0"
### <pkg:pkg2.1>
opam-version: "2.0"
### <pkg:var-with-plus.1>
opam-version: "2.0"
build: [
  ["echo" "%{?pkg++:installed:}%"]
  ["echo" "%{?pkg+:installed:}%"]
  ["echo" "%{?pkg+a:installed:}%"]
  ["echo" "%{?pkg++a:installed:}%"]
  ["echo" "%{?pkg1+pkg2:installed:}%"]
  ["echo" "%{pkg1+pkg2:installed}%"]
]
depopts: [
  "pkg++"
  "pkg+"
  "pkg+a"
  "pkg++a"
  "pkg1"
  "pkg2"
]
### opam switch create test --empty
### : Test the behaviour of %{?pkg+with+pluses:var:false}%
### : See https://github.com/ocaml/opam/pull/5840
